{
  "name": "step-engine",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run index.tsx",
    "test": "bun test ./src",
    "dev": "bun --watch index.tsx",
    "build": "bun run build:css && bun run build:js",
    "build:css": "sass src/styles/main.scss:resources/public/style.css",
    "build:js": "for file in src/scripts/*.ts; do bun build \"$file\" --outfile \"resources/public/$(basename \"$file\" .ts).js\"; done",
    "watch:css": "sass --watch src/styles/main.scss:resources/public/style.css",
    "lint": "eslint .",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "fmt": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@types/bun": "^1.3.9",
    "chart.js": "^4.5.1",
    "eslint-formatter-unix": "^9.0.1",
    "glob": "^13.0.0",
    "hono": "^4.11.4",
    "marked": "^17.0.1",
    "playwright": "^1.58.2",
    "sass": "^1.97.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
