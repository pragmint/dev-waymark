{
  "name": "step-engine",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "bun ./scripts/start.ts",
    "dev": "bun b && bun ./scripts/dev.ts",
    "b": "bun ./scripts/build.ts",
    "b:prod": "bun ./scripts/build.ts --prod",
    "watch:css": "sass --watch src/styles/main.scss:public/style.css",
    "check": "prettier --check . && eslint . && tsc",
    "check:commit": "bun scripts/check-no-manual-interfaces-in-schemas.ts",
    "fix": "prettier --write . && eslint . --fix",
    "mirror": "bun mirror.ts http://localhost:3000/ mirror",
    "test:pw": "bun b && playwright test",
    "clean": "bun ./scripts/clean.ts"
  },
  "dependencies": {
    "@types/bun": "^1.3.9",
    "chart.js": "^4.5.1",
    "eslint-formatter-unix": "^9.0.1",
    "glob": "^13.0.0",
    "hono": "^4.11.4",
    "marked": "^17.0.1",
    "playwright": "^1.58.2",
    "sass": "^1.97.2",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cyclomatic-complexity": "^2.0.11",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
