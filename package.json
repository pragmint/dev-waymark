{
  "name": "dev-waymark",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "start": "bun scripts/start.ts",
    "b": "bun scripts/build.ts",
    "b:prod": "bun scripts/build.ts --prod",
    "clean": "bun scripts/clean.ts",
    "check": "prettier --check . && eslint . && tsc --noEmit && bun scripts/check-no-manual-interfaces-in-schemas.ts",
    "fix": "prettier --write . && eslint --fix .",
    "check:commit": "prettier --check . && eslint . && tsc --noEmit",
    "migrate": "bun scripts/migrate.ts",
    "rollback": "bun scripts/rollback.ts",
    "test": "NODE_ENV=test bun test",
    "test:e2e": "NODE_ENV=test PLAYWRIGHT_HTML_OPEN=never bunx playwright test",
    "install-hooks": "bun scripts/install-hooks.ts"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "pg": "^8.21.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "bun-types": "^1.3.14",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-cyclomatic-complexity": "^1.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.0.0"
  }
}
