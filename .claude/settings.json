{
  "permissions": {
    "allow": [
      "Bash(bun test:*)",
      "Bash(bun check)",
      "Bash(bun run check)",
      "Bash(bun fix)",
      "Bash(bun run fix)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(tree *)",
      "Bash(echo *)"
    ],
    "deny": ["Read(dist)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/claude_hooks/check.sh"
          }
        ]
      }
    ]
  }
}
