{
  "permissions": {
    "allow": [
      "Bash(bun test:*)",
      "Bash(bun run lint)",
      "Bash(bun run lint:fix)",
      "Bash(ls *)",
      "Bash(grep *)",
      "Bash(tree *)",
      "Bash(echo *)"
    ],
    "deny": ["Read(resources/public)"]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/runLint.sh"
          }
        ]
      }
    ]
  }
}
