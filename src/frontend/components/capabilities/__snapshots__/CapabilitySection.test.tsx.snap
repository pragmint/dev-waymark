exports[`CapabilitySection renders fallback progress bar when no maturity levels 1`] = `"<section class="capability-section"><h2>Current State</h2><div><div class="maturity-level"><div class="maturity-level-header"><h3>Maturity Level: 2</h3><span class="maturity-level-label">Developing</span></div><div class="maturity-progress"><div class="maturity-progress-bar"><div class="maturity-progress-fill" style="width: 50%"></div></div><div class="maturity-levels"><span class="level achieved">1</span><span class="level achieved">2</span><span class="level ">3</span><span class="level ">4</span></div></div></div><p>The organization is currently at level 2, demonstrating developing implementation of this capability.</p></div></section>"`;

exports[`CapabilitySection renders fallback with justification 1`] = `"<section class="capability-section"><h2>Current State</h2><div><div class="maturity-level"><div class="maturity-level-header"><h3>Maturity Level: 3</h3><span class="maturity-level-label">Defined</span></div><div class="maturity-progress"><div class="maturity-progress-bar"><div class="maturity-progress-fill" style="width: 75%"></div></div><div class="maturity-levels"><span class="level achieved">1</span><span class="level achieved">2</span><span class="level achieved">3</span><span class="level ">4</span></div></div></div><p>The organization is currently at level 3, demonstrating defined implementation of this capability.</p><div class="justification-section"><h4 class="justification-header">Justification</h4><div class="justification-text"><p>Line one</p><p>Line two</p></div></div></div></section>"`;

