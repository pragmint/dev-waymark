# Dev Waymark — environment configuration example
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4040

# ── Source database (client / analytical data) ────────────────────────────────
# The source database holds the entity + metadata records that Dev Waymark reads.
# Dev Waymark never owns this data — it connects to it read-only.
#
# Supported adapters: sqlite | postgres | redshift

# Example A — local SQLite (these are the default values, this config isn't required)
DEV_WAYMARK_SOURCE_DB_ADAPTER=sqlite
DEV_WAYMARK_SOURCE_DB_URL=sqlite:///dev-waymark.sqlite
DEV_WAYMARK_SOURCE_DB_NAME=default

# Example B — Postgres
# DEV_WAYMARK_SOURCE_DB_ADAPTER=postgres
# DEV_WAYMARK_SOURCE_DB_URL=postgresql://user:password@localhost:5432/client_source
# DEV_WAYMARK_SOURCE_DB_NAME=default

# Example C — Amazon Redshift
# DEV_WAYMARK_SOURCE_DB_ADAPTER=redshift
# DEV_WAYMARK_SOURCE_DB_URL=redshift://user:password@redshift-host:5439/warehouse
# DEV_WAYMARK_SOURCE_DB_NAME=default

# ── Application state database (Dev Waymark-owned state) ──────────────────────
# Stores dashboards, saved views, report definitions, and other Dev Waymark state.
# Can be a different database from the source — configure independently.
#
# Supported adapters: sqlite | postgres

# Example A — local SQLite (these are the default values, this config isn't required)
DEV_WAYMARK_APP_DB_ADAPTER=sqlite
DEV_WAYMARK_APP_DB_URL=sqlite:///dev-waymark-app.sqlite

# Example B — Postgres
# DEV_WAYMARK_APP_DB_ADAPTER=postgres
# DEV_WAYMARK_APP_DB_URL=postgresql://user:password@localhost:5432/dev_waymark_app

# ── Legacy (deprecated) ───────────────────────────────────────────────────────
# DATABASE_PATH is no longer used. Set DEV_WAYMARK_SOURCE_DB_URL instead.
# If neither is set, the source defaults to sqlite:///dev-waymark.sqlite.
