# Step Engine — environment configuration example
# Copy this file to .env and fill in your values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4040

# ── Source database (client / analytical data) ────────────────────────────────
# The source database holds the entity + metadata records that Step Engine reads.
# Step Engine never owns this data — it connects to it read-only.
#
# Supported adapters: sqlite | postgres | redshift

# Example A — local SQLite (these are the default values, this config isn't required)
STEP_ENGINE_SOURCE_DB_ADAPTER=sqlite
STEP_ENGINE_SOURCE_DB_URL=sqlite:///step-engine.sqlite
STEP_ENGINE_SOURCE_DB_NAME=default

# Example B — Postgres
# STEP_ENGINE_SOURCE_DB_ADAPTER=postgres
# STEP_ENGINE_SOURCE_DB_URL=postgresql://user:password@localhost:5432/client_source
# STEP_ENGINE_SOURCE_DB_NAME=default

# Example C — Amazon Redshift
# STEP_ENGINE_SOURCE_DB_ADAPTER=redshift
# STEP_ENGINE_SOURCE_DB_URL=redshift://user:password@redshift-host:5439/warehouse
# STEP_ENGINE_SOURCE_DB_NAME=default

# ── Application state database (Step Engine-owned state) ──────────────────────
# Stores dashboards, saved views, report definitions, and other Step Engine state.
# Can be a different database from the source — configure independently.
#
# Supported adapters: sqlite | postgres

# Example A — local SQLite (these are the default values, this config isn't required)
STEP_ENGINE_APP_DB_ADAPTER=sqlite
STEP_ENGINE_APP_DB_URL=sqlite:///step-engine-app.sqlite

# Example B — Postgres
# STEP_ENGINE_APP_DB_ADAPTER=postgres
# STEP_ENGINE_APP_DB_URL=postgresql://user:password@localhost:5432/step_engine_app

# ── Legacy (deprecated) ───────────────────────────────────────────────────────
# DATABASE_PATH is no longer used. Set STEP_ENGINE_SOURCE_DB_URL instead.
# If neither is set, the source defaults to sqlite:///step-engine.sqlite.
