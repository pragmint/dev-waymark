# Environment for the Playwright e2e run. Loaded by playwright.config.ts and
# passed to the test server. Copy to `.env.e2e` (gitignored) to activate.
#
# Any key set here overrides the SQLite defaults hard-coded in
# playwright.config.ts. Unset keys keep those defaults.

# Enables the e2e test harness: truncates the app-state DB on startup and
# mounts the /test/* endpoints Playwright uses to seed presets/dashboards/etc.
DEV_WAYMARK_TEST_MODE=1

# Installs the compact e2e source seed (see src/db/source/e2eSeed.ts) on every
# boot. Always TRUNCATEs the source first — never point at a real source DB.
DEV_WAYMARK_SOURCE_DB_SEED=e2e

# ── Default: Postgres via devenv.nix ─────────────────────────────────────────
# `bun test:e2e` starts devenv itself when the port isn't already listening
# (see test/globalSetup.ts). The *_e2e database names keep dev data isolated
# from test runs on the same Postgres instance.
DEV_WAYMARK_SOURCE_DB_ADAPTER=postgres
DEV_WAYMARK_SOURCE_DB_URL=postgresql://waymark:waymark@localhost:5433/waymark_source_e2e
DEV_WAYMARK_APP_DB_ADAPTER=postgres
DEV_WAYMARK_APP_DB_URL=postgresql://waymark:waymark@localhost:5433/waymark_app_e2e

# ── Alternative: in-memory SQLite ────────────────────────────────────────────
# No devenv required. Comment the DEV_WAYMARK_*_DB_* block above and uncomment
# these to run without external services.
# DEV_WAYMARK_SOURCE_DB_ADAPTER=sqlite
# DEV_WAYMARK_SOURCE_DB_URL=sqlite:///:memory:
# DEV_WAYMARK_APP_DB_ADAPTER=sqlite
# DEV_WAYMARK_APP_DB_URL=sqlite:///:memory:
