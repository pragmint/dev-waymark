# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
public/

# Environment variables
.env
.env.e2e
.env.local
.env.*.local

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# SQLite databases (generated — run `bun run pipelines/seed.ts` to recreate)
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Claude session memory (local to this machine)
memory/

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Seed snapshot cache (rebuilt from goldenSeed.ts on demand)
.cache/

# devenv / direnv artefacts
.devenv/
.direnv/
.devenv.flake.nix

# Marker written by test/globalSetup.ts when it starts devenv itself
.devenv-e2e-owned

# Claude hooks sentinel (touch to disable Stop hooks during planning/analysis)
.no-hooks

# OS files
Thumbs.db

# AI tool settings
.claude/settings.local.json

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/playwright/.auth/
